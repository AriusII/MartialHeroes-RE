; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="MartialHeroes.Client.Godot"
run/main_scene="uid://ftdqt2j1mmt8"
config/features=PackedStringArray("4.6", "C#", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

FontBootstrap="*res://Autoload/FontBootstrap.cs"
ClientContext="*res://Autoload/ClientContext.cs"
McpBridgeGame="*res://mcp_bridge_game.gd"

[display]

window/size/viewport_width=1024
window/size/viewport_height=768
window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="MartialHeroes.Client.Godot"

[editor_plugins]

enabled=PackedStringArray("res://addons/mcp_bridge/plugin.cfg")

[environment]

defaults/default_clear_color=Color(0, 0, 0, 1)

[importer_defaults]

animation_library={
&"animation/fps": 60.0
}

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
