[gd_scene load_steps=8 format=3 uid="uid://world_scene"]

; Root orchestrator: GameLoop — drains the Application event bus each frame.
[ext_resource type="Script" path="res://World/GameLoop.cs" id="1"]

; ActorRegistry — manages VisualActor nodes (spawned/moved/despawned).
[ext_resource type="Script" path="res://World/ActorRegistry.cs" id="2"]

; HUD — health bar + state label + actor count.
[ext_resource type="Script" path="res://HUD/GameHud.cs" id="3"]

; InputRouter — translates Godot input events to IApplicationUseCases calls.
[ext_resource type="Script" path="res://Input/InputRouter.cs" id="4"]

; SyntheticWorldFeeder — debug event feeder for offline demonstration.
[ext_resource type="Script" path="res://Debug/SyntheticWorldFeeder.cs" id="5"]

; Minimal DirectionalLight + Camera placeholder.
