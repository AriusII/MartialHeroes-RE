[gd_scene load_steps=5 format=3 uid="uid://cn3q7w8xv2m4k0"]

; Root orchestrator: GameLoop — drains the Application event bus each frame.
; NOTE: in Godot 4 the `script` is a PROPERTY assignment on its own line BELOW the
; [node] header (`script = ExtResource(...)`), NOT an inline header attribute. Putting
; it in the header is silently ignored -> the node ends up with no script (gray screen).
; GameHud.cs was removed in Campaign 17 HUD-II — HudMaster is built programmatically by InGameScene.
[ext_resource type="Script" uid="uid://b40qcootw1kr6" path="res://World/GameLoop.cs" id="1"]
[ext_resource type="Script" uid="uid://dion3hgcbj2l7" path="res://World/ActorRegistry.cs" id="2"]
[ext_resource type="Script" uid="uid://b5d0wrs10eihb" path="res://Input/InputRouter.cs" id="4"]
; Environment: background_mode=Color, neutral grey — no ProceduralSkyMaterial at any frame.
; The ProceduralSkyMaterial + Sky sub-resources were removed: at frame-0 the sky was a visible
; procedural blue sky before EnvironmentNode.Configure replaces it at runtime. The original has
; no procedural sky; EnvironmentNode drives the sky from the per-area environment bins each frame.
; spec: Docs/RE/specs/environment.md §3.1 — per-area load sequence drives sky/background.
; spec: Docs/RE/specs/environment.md §6.1 — neutral-grey fallback when environment data absent.
; spec: Docs/RE/specs/rendering.md — no procedural sky in the original pipeline.
[sub_resource type="Environment" id="Environment_1"]
background_mode = 1
background_color = Color(0.45, 0.45, 0.45, 1)
ambient_light_source = 3
ambient_light_color = Color(1, 1, 1, 1)
ambient_light_sky_contribution = 0.5
ambient_light_energy = 1.0
; Tonemap: Linear pass-through (mode 0), exposure identity — the original DX8 client has NO
; tonemap/exposure pass; EnvironmentNode.Configurator forces these same values at runtime, so the
; frame-0 .tscn values must match to avoid a brief Filmic/over-exposed first frame.
; spec: Docs/RE/specs/rendering.md §6 — post chain is bright-copy → blur → composite → present; NO tonemap.
tonemap_mode = 0
tonemap_exposure = 1.0
tonemap_white = 6.0
glow_enabled = false
ssao_enabled = false
ssil_enabled = false
sdfgi_enabled = false

[node name="World" type="Node"]
script = ExtResource("1")

[node name="ActorRegistry" type="Node" parent="."]
script = ExtResource("2")

[node name="InputRouter" type="Node" parent="."]
script = ExtResource("4")

[node name="DirectionalLight3D" type="DirectionalLight3D" parent="."]
transform = Transform3D(0.707107, -0.5, 0.5, 0, 0.707107, 0.707107, -0.707107, -0.5, 0.5, 0, 50, 0)
; light_energy 1.0: the original applies the directional color_A RAW at energy 1.0 (no multiplier);
; EnvironmentNode.Configurator sets LightEnergy = 1.0f at runtime, so align frame-0 to match.
; spec: Docs/RE/specs/environment.md §6.2a — directional light applied RAW, energy 1.0.
light_energy = 1.0
light_color = Color(1, 0.96, 0.88, 1)
shadow_enabled = true
directional_shadow_max_distance = 2000.0

; No static Camera3D: RealWorldRenderer.SpawnCamera removes any pre-existing static camera and
; installs the spec-faithful CameraController (Third-person orbit, FOV 65 / near 5 / far 15000) at
; runtime. A static camera here would be dead (immediately QueueFree'd) and only contradict the spec.
; spec: Docs/RE/specs/camera_movement.md §A.7 — in-world gameplay camera FOV 65, near 5, far 15000.
[node name="WorldEnvironment" type="WorldEnvironment" parent="."]
environment = SubResource("Environment_1")
