[gd_scene load_steps=12 format=3 uid="uid://world_scene"]

; Root orchestrator: GameLoop — drains the Application event bus each frame.
[ext_resource type="Script" path="res://World/GameLoop.cs" id="1"]

; ActorRegistry — manages VisualActor nodes (spawned/moved/despawned).
[ext_resource type="Script" path="res://World/ActorRegistry.cs" id="2"]

; HUD — health bar + state label + actor count.
[ext_resource type="Script" path="res://HUD/GameHud.cs" id="3"]

; InputRouter — translates Godot input events to IApplicationUseCases calls.
[ext_resource type="Script" path="res://Input/InputRouter.cs" id="4"]

; SyntheticWorldFeeder — debug event feeder for offline demonstration.
[ext_resource type="Script" path="res://Debug/SyntheticWorldFeeder.cs" id="5"]

; --- ProceduralSkyMaterial: blue sky with horizon gradient ---
[sub_resource type="ProceduralSkyMaterial" id="ProceduralSkyMaterial_1"]
sky_top_color = Color(0.1, 0.35, 0.78, 1)
sky_horizon_color = Color(0.62, 0.78, 0.95, 1)
sky_curve = 0.08
ground_bottom_color = Color(0.18, 0.12, 0.05, 1)
ground_horizon_color = Color(0.42, 0.35, 0.25, 1)
sun_angle_max = 32.0
sun_curve = 0.12

; --- Sky wrapper ---
[sub_resource type="Sky" id="Sky_1"]
sky_material = SubResource("ProceduralSkyMaterial_1")
process_mode = 0

; --- Environment: sky background + ambient from sky + linear tonemap ---
[sub_resource type="Environment" id="Environment_1"]
background_mode = 2
sky = SubResource("Sky_1")
ambient_light_source = 3
ambient_light_color = Color(1, 1, 1, 1)
ambient_light_sky_contribution = 0.6
ambient_light_energy = 0.8
tonemap_mode = 1
tonemap_exposure = 1.0
tonemap_white = 1.0
glow_enabled = false
ssao_enabled = false
ssil_enabled = false
sdfgi_enabled = false

[node name="World" type="Node" script=ExtResource("1")]

[node name="ActorRegistry" type="Node" parent="." script=ExtResource("2")]

[node name="HUD" type="Control" parent="." script=ExtResource("3")]

[node name="InputRouter" type="Node" parent="." script=ExtResource("4")]

[node name="SyntheticWorldFeeder" type="Node" parent="." script=ExtResource("5")]

[node name="DirectionalLight3D" type="DirectionalLight3D" parent="."]
transform = Transform3D(0.707107, -0.5, 0.5, 0, 0.707107, 0.707107, -0.707107, -0.5, 0.5, 0, 10, 0)
light_energy = 1.2
shadow_enabled = true

[node name="Camera3D" type="Camera3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 0.707107, -0.707107, 0, 0.707107, 0.707107, 0, 25, 25)
fov = 60.0
near = 0.5
far = 5000.0

[node name="WorldEnvironment" type="WorldEnvironment" parent="."]
environment = SubResource("Environment_1")
