<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MartialHeroes.Explorer.Files.ViewModels"
        xmlns:models="using:MartialHeroes.Explorer.Files.Models"
        xmlns:controls="using:MartialHeroes.Explorer.Files.Controls"
        x:Class="MartialHeroes.Explorer.Files.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1280" Height="820"
        MinWidth="900" MinHeight="560"
        Title="Martial Heroes — VFS File Explorer">

    <Window.DataTemplates>
        <DataTemplate DataType="models:TextDocument">
            <TextBox Text="{Binding Text}"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="NoWrap"
                     FontFamily="Cascadia Mono, Consolas, monospace"
                     FontSize="12"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto" />
        </DataTemplate>

        <DataTemplate DataType="models:TableDocument">
            <controls:TableView Document="{Binding}" />
        </DataTemplate>
    </Window.DataTemplates>

    <DockPanel>

        <Border DockPanel.Dock="Top" Background="#1B1D23" Padding="12,8" BorderBrush="#2C2F38"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                <TextBlock Grid.Column="0" Text="VFS Explorer" FontSize="16" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,16,0" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button x:Name="OpenClientButton" Content="Open client…" />
                    <Button Content="Reload" Command="{Binding ReloadCommand}" />
                </StackPanel>
                <TextBlock Grid.Column="2" Text="{Binding ClientDir}" Foreground="#8A90A0"
                           VerticalAlignment="Center" Margin="16,0" TextTrimming="CharacterEllipsis" />
                <ProgressBar Grid.Column="3" IsIndeterminate="True" Width="120" Height="4"
                             IsVisible="{Binding IsBusy}" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Border DockPanel.Dock="Top" Background="#16181D" BorderBrush="#2C2F38" BorderThickness="0,0,0,1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ListBox ItemsSource="{Binding Tabs}" SelectedItem="{Binding SelectedTab}"
                         Background="Transparent" BorderThickness="0" Padding="8,4">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="4" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:FormatTabViewModel">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="6,4">
                                <TextBlock Text="{Binding Glyph}" FontSize="15" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Title}" FontSize="13" VerticalAlignment="Center" />
                                <Border Background="#2C3140" CornerRadius="8" Padding="6,1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FileCount}" FontSize="11" Foreground="#AEB4C2" />
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#1B1D23" Padding="12,5" BorderBrush="#2C2F38"
                BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusText}" Foreground="#8A90A0" FontSize="12" />
        </Border>

        <Grid ColumnDefinitions="340,4,*">

            <DockPanel Grid.Column="0" Background="#1E2027">
                <Border DockPanel.Dock="Top" Padding="10,8">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding SelectedTab.Description}" Foreground="#8A90A0"
                                   FontSize="11" TextWrapping="Wrap" />
                        <TextBox Text="{Binding FilterText}" PlaceholderText="Filter by path…" FontSize="12" />
                    </StackPanel>
                </Border>
                <TextBlock DockPanel.Dock="Bottom" Margin="10,6"
                           Foreground="#6C7180" FontSize="11"
                           Text="{Binding Files.Count, StringFormat='{}{0:N0} files listed'}" />
                <ListBox ItemsSource="{Binding Files}" SelectedItem="{Binding SelectedFile}"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:VfsFileNode">
                            <StackPanel Spacing="1" Margin="2,3">
                                <TextBlock Text="{Binding Name}" FontSize="13" TextTrimming="CharacterEllipsis" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding Directory}" Foreground="#6C7180" FontSize="10"
                                               TextTrimming="CharacterEllipsis" MaxWidth="220" />
                                    <TextBlock Text="{Binding SizeDisplay}" Foreground="#6C7180" FontSize="10" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <GridSplitter Grid.Column="1" Background="#2C2F38" ResizeDirection="Columns" />

            <DockPanel Grid.Column="2" Background="#12131A">
                <Border DockPanel.Dock="Top" Padding="14,10" Background="#1B1D23"
                        BorderBrush="#2C2F38" BorderThickness="0,0,0,1">
                    <StackPanel Spacing="2">
                        <TextBlock Text="{Binding SelectedFile.Path}" FontSize="14" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding CurrentDocument.Summary}" Foreground="#8A90A0" FontSize="11" />
                    </StackPanel>
                </Border>

                <Panel>
                    <ContentControl Content="{Binding CurrentDocument}" Margin="6" />
                    <TextBlock Text="Select a file to preview its contents."
                               Foreground="#5A5F6C" FontSize="14"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsVisible="{Binding CurrentDocument, Converter={x:Static ObjectConverters.IsNull}}" />
                </Panel>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>