{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enabledMcpjsonServers": ["ida", "godot"],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/session_primer.py\"", "timeout": 8 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/prompt_primer.py\"", "timeout": 6 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/firewall_guard.py\"", "timeout": 8 },
          { "type": "command", "command": "python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/layer_dependency_guard.py\"", "timeout": 8 }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/firewall_guard.py\"", "timeout": 8 }
        ]
      },
      {
        "matcher": "mcp__ida__.*",
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/firewall_guard.py\"", "timeout": 6 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/cs_post_edit.py\"", "timeout": 70 },
          { "type": "command", "command": "python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/csharp_guard.py\"", "timeout": 8 },
          { "type": "command", "command": "python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/godot_guard.py\"", "timeout": 6 },
          { "type": "command", "command": "python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/kit_guard.py\"", "timeout": 6 }
        ]
      },
      {
        "matcher": "mcp__ida__.*",
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/re_provenance_logger.py\"", "timeout": 6 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/session_end.py\"", "timeout": 6 }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/session_end.py\"", "timeout": 6 }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/session_end.py\"", "timeout": 6 }
        ]
      }
    ]
  }
}
