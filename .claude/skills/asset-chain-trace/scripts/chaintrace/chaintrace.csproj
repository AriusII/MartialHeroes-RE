<Project Sdk="Microsoft.NET.Sdk">

    <!--
        chaintrace — THROWAWAY asset-chain existence tracer for the Martial Heroes client.

        This project is INTENTIONALLY NOT a member of MartialHeroes.slnx and must NEVER be
        added to it. It lives under .claude/skills/asset-chain-trace/scripts/ and is run in
        place with `dotnet run -c Release`. Its bin/obj are transient build output, never committed.

        It references the production VFS library by ABSOLUTE path so it always tracks the live
        API surface (MappedVfsArchive.Open / GetEntries / Contains). If the API drifts, this
        harness fails to compile — fix the call site here, never the library.

        INDEX/EXISTENCE ONLY: this harness intentionally does NOT call GetFileContent and has
        no decode/dump path. It reports membership, size, and offset — never payload bytes.
    -->

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <LangVersion>14.0</LangVersion>
        <!-- The referenced Assets.Vfs uses unsafe memory-mapping internals. -->
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <!-- Loose harness; never let it ride along in any solution build. -->
        <IsPackable>false</IsPackable>
    </PropertyGroup>

    <ItemGroup>
        <!-- Absolute path so the harness runs from any working directory.
             Adjust the drive/root here if the repository is cloned elsewhere. -->
        <ProjectReference Include="C:\Users\Arius\RiderProjects\MartialHeroes\03.Storage.Assets\MartialHeroes.Assets.Vfs\MartialHeroes.Assets.Vfs.csproj" />
    </ItemGroup>

    <!--
        CP949 (Korean code page 949) decoding for client text tables is provided by
        System.Text.Encoding.CodePages, which ships in the .NET 10 shared framework — no
        PackageReference is needed. Program.cs registers it via
        Encoding.RegisterProvider(CodePagesEncodingProvider.Instance).
    -->

</Project>
