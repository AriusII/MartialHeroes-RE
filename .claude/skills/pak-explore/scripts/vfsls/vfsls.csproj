<Project Sdk="Microsoft.NET.Sdk">

    <!--
        vfsls — THROWAWAY VFS inspection harness for the Martial Heroes client.

        This project is INTENTIONALLY NOT a member of MartialHeroes.slnx and must NEVER be
        added to it. It lives under .claude/skills/vfs-inspect/scripts/ and is run in place
        with `dotnet run -c Release`. Its bin/obj are transient build output, not committed.

        It references the production VFS + Parsers libraries by ABSOLUTE path so it always
        tracks the live API surface (MappedVfsArchive.Open / GetEntries / GetFileContent /
        Contains). If the API drifts, this harness fails to compile — fix the call site here,
        never the library.
    -->

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <LangVersion>14.0</LangVersion>
        <!-- The referenced Assets.Vfs uses unsafe memory-mapping internals. -->
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <!-- This is a loose harness; do not let it ride along in any solution build. -->
        <IsPackable>false</IsPackable>
    </PropertyGroup>

    <ItemGroup>
        <!--
            Absolute paths so the harness can be run from any working directory.
            Adjust the drive/root here if the repository is cloned elsewhere.
        -->
        <ProjectReference Include="C:\Users\Arius\RiderProjects\MartialHeroes\03.Storage.Assets\MartialHeroes.Assets.Vfs\MartialHeroes.Assets.Vfs.csproj" />
        <ProjectReference Include="C:\Users\Arius\RiderProjects\MartialHeroes\03.Storage.Assets\MartialHeroes.Assets.Parsers\MartialHeroes.Assets.Parsers.csproj" />
        <!-- Mapping = the modern-format bridge used by the `convert` subcommand (mesh→GLB, texture→PNG, xeff→JSON). -->
        <ProjectReference Include="C:\Users\Arius\RiderProjects\MartialHeroes\03.Storage.Assets\MartialHeroes.Assets.Mapping\MartialHeroes.Assets.Mapping.csproj" />
    </ItemGroup>

    <!--
        CP949 (Korean code page 949) decoding for all client text payloads is provided by
        System.Text.Encoding.CodePages, which ships in the .NET 10 shared framework — no
        PackageReference is needed. Program.cs registers it via
        Encoding.RegisterProvider(CodePagesEncodingProvider.Instance).
    -->

</Project>
