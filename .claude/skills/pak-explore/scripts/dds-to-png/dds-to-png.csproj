<Project Sdk="Microsoft.NET.Sdk">

    <!--
        dds-to-png — THROWAWAY harness to decode DDS atlases (DXT1/2/3/5) to PNG for visual inspection.
        NOT a solution member. Never add to MartialHeroes.slnx. Never commit.
        DXT2 = DXT3 block layout but with premultiplied alpha; we un-premultiply on decode.
    -->

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <LangVersion>14.0</LangVersion>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <IsPackable>false</IsPackable>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="C:\Users\Arius\RiderProjects\MartialHeroes\03.Storage.Assets\MartialHeroes.Assets.Vfs\MartialHeroes.Assets.Vfs.csproj" />
        <PackageReference Include="SixLabors.ImageSharp" Version="3.1.5" />
    </ItemGroup>

</Project>
